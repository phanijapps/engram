{
  "name": "engram-viz-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Thin Hono REST server that proxies engram codegraph operations via @engram/node N-API.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
