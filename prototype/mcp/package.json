{
  "name": "engram-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "stdio MCP server that exposes Engram as a local tool backend",
  "main": "dist/mcp-stdio.js",
  "bin": {
    "engram-mcp": "dist/mcp-stdio.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/mcp-stdio.ts",
    "build": "tsc",
    "start": "node dist/mcp-stdio.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@engram/node": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
